# LingText Environment Variables
# ================================
# NOTE: LingText now uses 100% LOCAL translation!
# No API keys required for translation functionality.
# All AI models run directly in your browser using WebGPU/WASM.

# Optional: Cloudflare Workers configuration (if deploying to Cloudflare)
# CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
# CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Development settings
# NODE_ENV=development
# PORT=5173
